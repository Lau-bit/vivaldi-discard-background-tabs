{
  "manifest_version": 3,
  "name": "Tab Parking Controls",
  "description": "Parks browser windows and discards every eligible real tab when you click the toolbar button.",
  "version": "1.0.0",
  "permissions": [
    "alarms",
    "contextMenus",
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tab parking controls",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
